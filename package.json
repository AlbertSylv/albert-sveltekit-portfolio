{
	"name": "albert-sveltekit-portfolio",
	"private": true,
	"version": "0.0.1",
	"engines": {
		"node": ">=20.19.0"
	},
	"type": "module",
	"scripts": {
		"dev": "node ./scripts/with-node.mjs ./node_modules/vite/bin/vite.js dev",
		"build": "node ./scripts/with-node.mjs ./node_modules/vite/bin/vite.js build",
		"preview": "node ./scripts/with-node.mjs ./node_modules/vite/bin/vite.js preview",
		"check": "node ./scripts/with-node.mjs ./node_modules/@sveltejs/kit/svelte-kit.js sync && node ./scripts/with-node.mjs ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "node ./scripts/with-node.mjs ./node_modules/@sveltejs/kit/svelte-kit.js sync && node ./scripts/with-node.mjs ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
		"vite": "^8.0.13"
	}
}
